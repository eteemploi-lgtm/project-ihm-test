* {
    box-sizing: border-box;
}

:root {
    --bg: #f4f7fb;
    --card: #ffffff;
    --border: #d7dfeb;
    --text: #1f2937;
    --muted: #6b7280;

    --primary: #2563eb;
    --primary-hover: #1d4ed8;

    --danger: #dc2626;
    --danger-hover: #b91c1c;

    --success-bg: #dcfce7;
    --success-text: #166534;

    --warning-bg: #fef3c7;
    --warning-text: #92400e;

    --error-bg: #fee2e2;
    --error-text: #991b1b;

    --shadow: 0 8px 24px rgba(15, 23, 42, 0.08);
    --radius: 14px;
}

html,
body {
    margin: 0;
    padding: 0;
    background: var(--bg);
    color: var(--text);
    font-family: Arial, Helvetica, sans-serif;
}

body {
    padding: 20px;
}

h2 {
    margin-top: 0;
    margin-bottom: 14px;
    font-size: 20px;
    color: #0f172a;
}

.row {
    display: flex;
    gap: 20px;
    flex-wrap: wrap;
}

.card {
    background: var(--card);
    border: 1px solid var(--border);
    border-radius: var(--radius);
    padding: 18px;
    min-width: 320px;
    flex: 1;
    box-shadow: var(--shadow);
}

.field {
    margin-bottom: 12px;
}

.field label {
    display: block;
    font-weight: 700;
    margin-bottom: 5px;
    font-size: 14px;
}

.field input,
.field textarea,
.field pre {
    width: 100%;
    box-sizing: border-box;
    padding: 10px 12px;
    border: 1px solid #cbd5e1;
    border-radius: 10px;
    background: #fff;
    color: var(--text);
    font-size: 14px;
}

.field input[readonly],
.field textarea[readonly] {
    background: #f8fafc;
    color: #475569;
}

.field small {
    display: block;
    margin-top: 4px;
    color: var(--muted);
    font-size: 12px;
}

textarea {
    resize: vertical;
    min-height: 120px;
}

pre {
    white-space: pre-wrap;
    word-break: break-word;
    min-height: 70px;
    background: #0f172a;
    color: #dbeafe;
    font-family: Consolas, Monaco, monospace;
    font-size: 13px;
    overflow-x: auto;
}

.actions {
    display: flex;
    gap: 10px;
    flex-wrap: wrap;
    margin-top: 10px;
}

button {
    padding: 10px 14px;
    border: none;
    border-radius: 10px;
    cursor: pointer;
    font-weight: 700;
    font-size: 14px;
    transition: background 0.2s ease, transform 0.06s ease, opacity 0.2s ease;
}

button:active {
    transform: translateY(1px);
}

button:disabled {
    opacity: 0.5;
    cursor: not-allowed;
}

.primary {
    background: var(--primary);
    color: #fff;
}

.primary:hover {
    background: var(--primary-hover);
}

.danger {
    background: var(--danger);
    color: #fff;
}

.danger:hover {
    background: var(--danger-hover);
}

.status-bar {
    margin-top: 12px;
    padding: 10px 12px;
    border-radius: 10px;
    font-weight: 700;
    border: 1px solid transparent;
}

.success {
    background: var(--success-bg);
    color: var(--success-text);
}

.warning {
    background: var(--warning-bg);
    color: var(--warning-text);
}

.error {
    background: var(--error-bg);
    color: var(--error-text);
}

.hidden {
    display: none !important;
}

.active {
    outline: 2px solid var(--primary);
    background: #dbeafe;
    color: #1d4ed8;
}

#globalConnectionChip {
    display: inline-flex;
    align-items: center;
    gap: 8px;
    margin-top: 12px;
    padding: 8px 12px;
    border-radius: 999px;
    font-weight: 700;
    background: #e5e7eb;
    color: #374151;
}

#connectionStatus {
    margin-top: 12px;
    font-weight: 700;
}

#logViewer {
    min-height: 180px;
    font-family: Consolas, Monaco, monospace;
    background: #0b1220;
    color: #dbeafe;
}

#logMeta {
    margin-top: 8px;
    color: var(--muted);
    font-size: 13px;
}

/* blocs détail */
#trameTestDetail div,
#trameSeqDetail div {
    margin-bottom: 8px;
}

#trameTestDetail strong,
#trameSeqDetail strong {
    color: #0f172a;
}

/* inputs réponse */
#NumMsg,
#identResponse,
#resultat,
#detail,
#NumSeq,
#memssd,
#NumMsgSeq,
#identResponseSeq,
#NumSeqb,
#memssdSeq {
    font-weight: 600;
}

/* responsive */
@media (max-width: 900px) {
    body {
        padding: 12px;
    }

    .row {
        flex-direction: column;
    }

    .card {
        min-width: auto;
        width: 100%;
    }
}





