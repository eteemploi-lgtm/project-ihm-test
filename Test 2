#include "protocol.h"

uint32_t calc_checksum_1020(const uint8_t *data, uint32_t len)
{
    uint32_t sum = 0;
    for (uint32_t i = 0; i < len; ++i)
    {
        sum = (sum + data[i]) & 0xFFFFFFFFu;
    }
    return sum;
}

static uint32_t read_le_u32(const uint8_t *p)
{
    return ((uint32_t)p[0]) |
           ((uint32_t)p[1] << 8) |
           ((uint32_t)p[2] << 16) |
           ((uint32_t)p[3] << 24);
}

int verify_frame_checksum(const uint8_t *frame1024)
{
    uint32_t calc = calc_checksum_1020(frame1024, FRAME_DATA_SIZE);
    uint32_t recv = read_le_u32(frame1024 + CHECKSUM_OFFSET);
    return calc == recv;
}


