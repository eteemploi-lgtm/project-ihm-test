typedef struct
{
    int sockfd;
    struct sockaddr_in localAddr;
    struct sockaddr_in remoteAddr;
} stUdpConnection;

int UdpInit(stUdpConnection *ctx,
            const char *localIp,
            uint16_t localPort,
            const char *remoteIp,
            uint16_t remotePort);

int UdpRecv(stUdpConnection *ctx,
            uint8_t *buffer,
            uint32_t bufferSize,
            uint32_t *receivedSize,
            struct sockaddr_in *srcAddr);

int UdpSendTo(stUdpConnection *ctx,
              const uint8_t *buffer,
              uint32_t bufferSize,
              const struct sockaddr_in *dstAddr);

void UdpClose(stUdpConnection *ctx);

