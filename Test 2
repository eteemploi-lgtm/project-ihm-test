#include "udp_connection.h"
#include <stdio.h>
#include <string.h>
#include <unistd.h>
#include <arpa/inet.h>
#include <sys/socket.h>

int UdpInit(stUdpConnection *ctx,
            const char *localIp,
            uint16_t localPort,
            const char *remoteIp,
            uint16_t remotePort)
{
    if (!ctx) return -1;

    memset(ctx, 0, sizeof(*ctx));

    ctx->sockfd = socket(AF_INET, SOCK_DGRAM, 0);
    if (ctx->sockfd < 0)
    {
        perror("socket");
        return -1;
    }

    ctx->localAddr.sin_family = AF_INET;
    ctx->localAddr.sin_port = htons(localPort);
    if (inet_pton(AF_INET, localIp, &ctx->localAddr.sin_addr) != 1)
    {
        perror("inet_pton local");
        close(ctx->sockfd);
        return -1;
    }

    if (bind(ctx->sockfd, (struct sockaddr *)&ctx->localAddr, sizeof(ctx->localAddr)) < 0)
    {
        perror("bind");
        close(ctx->sockfd);
        return -1;
    }

    ctx->remoteAddr.sin_family = AF_INET;
    ctx->remoteAddr.sin_port = htons(remotePort);
    if (inet_pton(AF_INET, remoteIp, &ctx->remoteAddr.sin_addr) != 1)
    {
        perror("inet_pton remote");
        close(ctx->sockfd);
        return -1;
    }

    return 0;
}

int UdpRecv(stUdpConnection *ctx,
            uint8_t *buffer,
            uint32_t bufferSize,
            uint32_t *receivedSize,
            struct sockaddr_in *srcAddr)
{
    if (!ctx || !buffer || !receivedSize || !srcAddr) return -1;

    socklen_t srcLen = sizeof(*srcAddr);
    int n = recvfrom(ctx->sockfd,
                     buffer,
                     bufferSize,
                     0,
                     (struct sockaddr *)srcAddr,
                     &srcLen);
    if (n < 0)
    {
        perror("recvfrom");
        return -1;
    }

    *receivedSize = (uint32_t)n;
    return 0;
}

int UdpSendTo(stUdpConnection *ctx,
              const uint8_t *buffer,
              uint32_t bufferSize,
              const struct sockaddr_in *dstAddr)
{
    if (!ctx || !buffer || !dstAddr) return -1;

    int n = sendto(ctx->sockfd,
                   buffer,
                   bufferSize,
                   0,
                   (const struct sockaddr *)dstAddr,
                   sizeof(*dstAddr));

    if (n < 0)
    {
        perror("sendto");
        return -1;
    }

    return n;
}

void UdpClose(stUdpConnection *ctx)
{
    if (ctx && ctx->sockfd > 0)
    {
        close(ctx->sockfd);
        ctx->sockfd = -1;
    }
}



