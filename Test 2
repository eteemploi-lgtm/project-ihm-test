function parseAckFrame(view) {
    const dv = new DataView(view.buffer);

    const ident = decodeChars(view, 0, 4);
    const numMsg = dv.getUint32(4, true);

    // ACK TEST / ERR
    if (ident === 'ACKT' || ident === 'ERR!') {
        return {
            type: 'TEST',
            ident,
            numMsg,
            resultCode: dv.getInt32(8, true),
            detailCode: dv.getInt32(12, true),
            numSeq: dv.getInt32(16, true),
            memSsd: dv.getInt32(20, true),
            raw: view
        };
    }

    // ACK SEQ
    if (ident === 'ACKS') {
        return {
            type: 'SEQ',
            ident,
            numMsg,
            numSeq: dv.getInt32(8, true),
            memSsd: dv.getInt32(12, true),
            raw: view
        };
    }

    // inconnu
    return {
        type: 'UNKNOWN',
        ident,
        numMsg,
        raw: view
    };
}


function handleCommandSequenceResponse(parsed) {
    if (typeof parsed === 'string') {
        const ident = identificationInput ? identificationInput.value : '--';
        const numSeq = numeroSequenceInput ? numeroSequenceInput.value : '0';

        if (NumMsgSeqField) NumMsgSeqField.value = NumeroMsgInput ? NumeroMsgInput.value : '';
        if (identResponseSeqField) identResponseSeqField.value = ident;
        if (NumSeqbField) NumSeqbField.value = numSeq;
        if (memssdSeqField) memssdSeqField.value = parsed;

        if (NumMsgSeqInfo) NumMsgSeqInfo.textContent = 'Réponse CMD SEQ';
        if (identResponseSeqInfo) identResponseSeqInfo.textContent = 'Ident utilisé';
        if (NumSeqbInfo) NumSeqbInfo.textContent = 'Séquence';
        if (memssdSeqInfo) memssdSeqInfo.textContent = 'Réponse texte';

        if (SequenceSendStatus) {
            SequenceSendStatus.textContent = 'Réponse Séquentielle reçue avec succès';
            SequenceSendStatus.className = 'status-bar success';
            SequenceSendStatus.classList.remove('hidden');
        }

        addLog('RECV', 'Réponse SEQ texte | ident=' + ident + ' | seq=' + numSeq);
        return;
    }

    if (NumMsgSeqField) NumMsgSeqField.value = String(parsed.numMsg ?? '');
    if (identResponseSeqField) identResponseSeqField.value = parsed.ident || '';
    if (NumSeqbField) NumSeqbField.value = String(parsed.numSeq ?? '');
    if (memssdSeqField) memssdSeqField.value = String(parsed.memSsd ?? '');

    if (NumMsgSeqInfo) NumMsgSeqInfo.textContent = 'Numéro message ACK SEQ';
    if (identResponseSeqInfo) identResponseSeqInfo.textContent = 'Identifiant ACK';
    if (NumSeqbInfo) NumSeqbInfo.textContent = 'Séquence renvoyée';
    if (memssdSeqInfo) memssdSeqInfo.textContent = 'Valeur mémoire SSD';

    if (SequenceSendStatus) {
        SequenceSendStatus.textContent =
            'Réponse Séquentielle reçue avec succès (SEQ=' + parsed.numSeq + ')';
        SequenceSendStatus.className = 'status-bar success';
        SequenceSendStatus.classList.remove('hidden');
    }

    addLog(
        'RECV',
        'ACK SEQ | ident=' + parsed.ident +
        ' | msg=' + parsed.numMsg +
        ' | seq=' + parsed.numSeq +
        ' | mem=' + parsed.memSsd
    );
}


