static void print_first_bytes(const uint8_t *buffer, uint32_t n)
{
    uint32_t max = n < 48 ? n : 48;
    printf("HEX[0..%u] :", max);
    for (uint32_t i = 0; i < max; ++i)
    {
        printf(" %02X", buffer[i]);
    }
    printf("\n");
}

static void fill_ack_test(const stFrameRaw *req, stAckTest *ack)
{
    memset(ack, 0, sizeof(*ack));

    memcpy(ack->ident, IDENT_ACKT, 4);
    ack->numMsg = req->numMsg;
    ack->resultCode = 0;
    ack->detailCode = 100;
    ack->numSeq = 1;
    ack->memSsd = 2048;

    ack->checksum = calc_checksum_1020((const uint8_t *)ack, FRAME_DATA_SIZE);
}

static void fill_ack_seq(const stSeqFrame *req, stAckSeq *ack)
{
    memset(ack, 0, sizeof(*ack));

    memcpy(ack->ident, IDENT_ACKS, 4);
    ack->numMsg = (uint32_t)req->numeroSeq;
    ack->numSeq = req->numeroSeq;   // très important : on reflète la séquence reçue
    ack->memSsd = 4096;

    ack->checksum = calc_checksum_1020((const uint8_t *)ack, FRAME_DATA_SIZE);
}

static void fill_ack_error(uint32_t msgNum, stAckTest *ack)
{
    memset(ack, 0, sizeof(*ack));

    memcpy(ack->ident, IDENT_ERR, 4);
    ack->numMsg = msgNum;
    ack->resultCode = -1;
    ack->detailCode = -1;
    ack->numSeq = -1;
    ack->memSsd = -1;

    ack->checksum = calc_checksum_1020((const uint8_t *)ack, FRAME_DATA_SIZE);
}

int SimuStaInit(stSimuSta *simu,
                const char *localIp,
                uint16_t localPort,
                const char *remoteIp,
                uint16_t remotePort)
{
    if (!simu) return -1;

    memset(simu, 0, sizeof(*simu));
    simu->running = 1;

    return UdpInit(&simu->udp, localIp, localPort, remoteIp, remotePort);
}

void SimuStaRun(stSimuSta *simu)
{
    if (!simu) return;

    uint8_t recvBuffer[FRAME_SIZE];
    struct sockaddr_in srcAddr;
    uint32_t recvSize = 0;

    printf("[SIMU] listening...\n");

    while (simu->running)
    {
        memset(recvBuffer, 0, sizeof(recvBuffer));
        recvSize = 0;

        if (UdpRecv(&simu->udp, recvBuffer, sizeof(recvBuffer), &recvSize, &srcAddr) != 0)
        {
            continue;
        }

        printf("\n[SIMU] reçu %u octets\n", recvSize);
        print_first_bytes(recvBuffer, recvSize);

        if (recvSize != FRAME_SIZE)
        {
            printf("[SIMU] taille invalide\n");

            stAckTest ackErr;
            fill_ack_error(0, &ackErr);
            UdpSendTo(&simu->udp, (const uint8_t *)&ackErr, sizeof(ackErr), &srcAddr);
            continue;
        }

        if (!verify_frame_checksum(recvBuffer))
        {
            printf("[SIMU] checksum invalide\n");

            stAckTest ackErr;
            fill_ack_error(0, &ackErr);
            UdpSendTo(&simu->udp, (const uint8_t *)&ackErr, sizeof(ackErr), &srcAddr);
            continue;
        }

        const stFrameRaw *raw = (const stFrameRaw *)recvBuffer;

        char ident[5] = {0};
        memcpy(ident, raw->ident, 4);

        printf("[SIMU] ident = %s\n", ident);
        printf("[SIMU] numMsg = %u\n", raw->numMsg);

        // Routage simple : TEST vs SEQ
        // Ici :
        // - si numMsg == 7 → TEST
        // - sinon → SEQ
        // Tu peux changer cette logique selon ton vrai protocole.
        if (raw->numMsg == 7)
        {
            stAckTest ack;
            fill_ack_test(raw, &ack);

            printf("[SIMU] -> ACK TEST\n");
            UdpSendTo(&simu->udp, (const uint8_t *)&ack, sizeof(ack), &srcAddr);
        }
        else
        {
            const stSeqFrame *seq = (const stSeqFrame *)recvBuffer;

            printf("[SIMU] numeroSeq = %d\n", seq->numeroSeq);
            printf("[SIMU] cap = %.4f | assiette = %.4f | bande = %.4f\n",
                   seq->cap, seq->assiette, seq->bande);
            printf("[SIMU] x = %.4f | y = %.4f | z = %.4f | vitesse = %.4f\n",
                   seq->x, seq->y, seq->z, seq->vitesse);
            printf("[SIMU] reemissionActive = %u | reemissionMs = %.4f\n",
                   seq->reemissionActive, seq->reemissionMs);

            stAckSeq ack;
            fill_ack_seq(seq, &ack);

            printf("[SIMU] -> ACK SEQ\n");
            UdpSendTo(&simu->udp, (const uint8_t *)&ack, sizeof(ack), &srcAddr);
        }
    }
}

void SimuStaStop(stSimuSta *simu)
{
    if (!simu) return;
    simu->running = 0;
    UdpClose(&simu->udp);
}


