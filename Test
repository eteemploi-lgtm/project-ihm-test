<!DOCTYPE html> 
<html lang="fr">
<head>
<meta charset="UTF-8"/>
<title>Schéma Gouvernes</title>
<style>
  * { margin:0; padding:0; box-sizing:border-box; }
  body {
    background:#020d1a; color:#dce8f5;
    font-family:"Segoe UI",sans-serif;
    display:flex; flex-direction:column;
    align-items:center; justify-content:center;
    min-height:100vh; padding:24px;
  }
  h2 { font-size:15px; color:#a8d0ff; margin-bottom:4px; text-align:center; }
  p  { font-size:11px; color:#4a6580; margin-bottom:20px; text-align:center; }

  .schema-wrap {
    background:#061525;
    border:1px solid rgba(42,140,255,0.2);
    border-radius:14px;
    padding:20px;
    width:520px;
  }

  svg { display:block; width:100%; }

  /* Étiquettes gouvernes */
  .gouv-label {
    font-size:11px; font-weight:700;
    font-family:"Segoe UI",sans-serif;
  }

  /* Valeurs */
  .gouv-val {
    font-size:10px;
    font-family:"Consolas",monospace;
  }

  /* Sliders de test */
  .controls {
    margin-top:16px;
    display:grid; grid-template-columns:1fr 1fr;
    gap:8px;
  }
  .ctrl-item {
    display:flex; flex-direction:column; gap:3px;
  }
  .ctrl-label {
    font-size:10px; font-weight:600;
    display:flex; justify-content:space-between;
  }
  input[type=range] {
    width:100%; accent-color:#2a8cff; height:4px;
  }
</style>
</head>
<body>

<h2>Schéma — 4 Gouvernes</h2>
<p>Corps central fixe · Gouvernes mobiles · Limite ±16.5°</p>

<div class="schema-wrap">
  <svg id="gouverneSVG" viewBox="0 0 480 480" xmlns="http://www.w3.org/2000/svg">
    <defs>
      <!-- Gradient corps central -->
      <radialGradient id="bodyGrad" cx="50%" cy="40%" r="60%">
        <stop offset="0%"   stop-color="#1a3a5c"/>
        <stop offset="100%" stop-color="#0a1f38"/>
      </radialGradient>
      <!-- Glow bleu -->
      <filter id="glow">
        <feGaussianBlur stdDeviation="3" result="blur"/>
        <feMerge><feMergeNode in="blur"/><feMergeNode in="SourceGraphic"/></feMerge>
      </filter>
      <!-- Shadow corps -->
      <filter id="shadow">
        <feDropShadow dx="0" dy="4" stdDeviation="8" flood-color="rgba(0,0,0,0.6)"/>
      </filter>
      <!-- Gradient pale gouverne -->
      <linearGradient id="gSupGrad" x1="0" y1="0" x2="1" y2="0">
        <stop offset="0%" stop-color="#7b5af5"/>
        <stop offset="100%" stop-color="#a78bfa"/>
      </linearGradient>
      <linearGradient id="gTriGrad" x1="0" y1="0" x2="1" y2="0">
        <stop offset="0%" stop-color="#2a8cff"/>
        <stop offset="100%" stop-color="#56a8ff"/>
      </linearGradient>
      <linearGradient id="gInfGrad" x1="0" y1="0" x2="0" y2="1">
        <stop offset="0%" stop-color="#18d97a"/>
        <stop offset="100%" stop-color="#4eeaa0"/>
      </linearGradient>
      <linearGradient id="gBabGrad" x1="1" y1="0" x2="0" y2="0">
        <stop offset="0%" stop-color="#f5a623"/>
        <stop offset="100%" stop-color="#ffc55a"/>
      </linearGradient>
    </defs>

    <!-- ── Fond grille légère ── -->
    <circle cx="240" cy="240" r="200" fill="none" stroke="rgba(42,140,255,0.05)" stroke-width="1"/>
    <circle cx="240" cy="240" r="150" fill="none" stroke="rgba(42,140,255,0.04)" stroke-width="1"/>
    <circle cx="240" cy="240" r="100" fill="none" stroke="rgba(42,140,255,0.06)" stroke-width="1"/>
    <line x1="40" y1="240" x2="440" y2="240" stroke="rgba(42,140,255,0.04)" stroke-width="1"/>
    <line x1="240" y1="40"  x2="240" y2="440" stroke="rgba(42,140,255,0.04)" stroke-width="1"/>

    <!-- ════════════════════════════
         GOUVERNE 1 — SUPÉRIEURE (haut)
         Partie fixe : ligne verticale haut
         Partie mobile : pale pivotante
    ════════════════════════════ -->
    <!-- Axe fixe -->
    <line x1="240" y1="60" x2="240" y2="140" stroke="#3a5a7a" stroke-width="3" stroke-linecap="round"/>
    <!-- Support fixe (ligne horizontale) -->
    <line x1="220" y1="60" x2="260" y2="60" stroke="#3a5a7a" stroke-width="2"/>
    <!-- Pale mobile groupe — pivotera autour de (240,140) -->
    <g id="govSup" transform="rotate(0, 240, 140)">
      <rect x="232" y="76" width="16" height="64" rx="6"
            fill="url(#gSupGrad)" opacity="0.92" filter="url(#glow)"/>
      <rect x="236" y="80" width="8" height="56" rx="3"
            fill="rgba(255,255,255,0.08)"/>
    </g>
    <!-- Étiquette -->
    <text x="240" y="48" text-anchor="middle" class="gouv-label" fill="#7b5af5">G1 Sup</text>
    <text id="valSup" x="240" y="56" text-anchor="middle" class="gouv-val" fill="#a78bfa">0.0°</text>

    <!-- ════════════════════════════
         GOUVERNE 2 — TRIBORD (droite)
    ════════════════════════════ -->
    <line x1="340" y1="240" x2="420" y2="240" stroke="#3a5a7a" stroke-width="3" stroke-linecap="round"/>
    <line x1="420" y1="220" x2="420" y2="260" stroke="#3a5a7a" stroke-width="2"/>
    <g id="govTri" transform="rotate(0, 340, 240)">
      <rect x="344" y="232" width="64" height="16" rx="6"
            fill="url(#gTriGrad)" opacity="0.92" filter="url(#glow)"/>
      <rect x="348" y="236" width="56" height="8" rx="3"
            fill="rgba(255,255,255,0.08)"/>
    </g>
    <text x="432" y="237" text-anchor="start" class="gouv-label" fill="#2a8cff">G2 Tri</text>
    <text id="valTri" x="432" y="247" text-anchor="start" class="gouv-val" fill="#56a8ff">0.0°</text>

    <!-- ════════════════════════════
         GOUVERNE 3 — INFÉRIEURE (bas)
    ════════════════════════════ -->
    <line x1="240" y1="340" x2="240" y2="420" stroke="#3a5a7a" stroke-width="3" stroke-linecap="round"/>
    <line x1="220" y1="420" x2="260" y2="420" stroke="#3a5a7a" stroke-width="2"/>
    <g id="govInf" transform="rotate(0, 240, 340)">
      <rect x="232" y="340" width="16" height="64" rx="6"
            fill="url(#gInfGrad)" opacity="0.92" filter="url(#glow)"/>
      <rect x="236" y="344" width="8" height="56" rx="3"
            fill="rgba(255,255,255,0.08)"/>
    </g>
    <text x="240" y="440" text-anchor="middle" class="gouv-label" fill="#18d97a">G3 Inf</text>
    <text id="valInf" x="240" y="450" text-anchor="middle" class="gouv-val" fill="#4eeaa0">0.0°</text>

    <!-- ════════════════════════════
         GOUVERNE 4 — BABORD (gauche)
    ════════════════════════════ -->
    <line x1="60" y1="240" x2="140" y2="240" stroke="#3a5a7a" stroke-width="3" stroke-linecap="round"/>
    <line x1="60" y1="220" x2="60" y2="260" stroke="#3a5a7a" stroke-width="2"/>
    <g id="govBab" transform="rotate(0, 140, 240)">
      <rect x="76" y="232" width="64" height="16" rx="6"
            fill="url(#gBabGrad)" opacity="0.92" filter="url(#glow)"/>
      <rect x="80" y="236" width="56" height="8" rx="3"
            fill="rgba(255,255,255,0.08)"/>
    </g>
    <text x="48" y="237" text-anchor="end" class="gouv-label" fill="#f5a623">G4 Bab</text>
    <text id="valBab" x="48" y="247" text-anchor="end" class="gouv-val" fill="#ffc55a">0.0°</text>

    <!-- ════════════════════════════
         CORPS CENTRAL
    ════════════════════════════ -->
    <ellipse cx="240" cy="240" rx="85" ry="68"
             fill="url(#bodyGrad)" stroke="rgba(42,140,255,0.35)"
             stroke-width="2" filter="url(#shadow)"/>
    <!-- Reflet -->
    <ellipse cx="232" cy="222" rx="38" ry="20"
             fill="rgba(255,255,255,0.04)"/>
    <!-- Label central -->
    <text x="240" y="236" text-anchor="middle"
          font-size="13" font-weight="700" fill="#a8d0ff"
          font-family="Segoe UI,sans-serif">SMO</text>
    <text x="240" y="250" text-anchor="middle"
          font-size="10" fill="#4a6580"
          font-family="Segoe UI,sans-serif">Propulsion</text>

    <!-- Axes de pivot (points) -->
    <circle cx="240" cy="140" r="5" fill="#3a5a7a" stroke="rgba(42,140,255,0.4)" stroke-width="1.5"/>
    <circle cx="340" cy="240" r="5" fill="#3a5a7a" stroke="rgba(42,140,255,0.4)" stroke-width="1.5"/>
    <circle cx="240" cy="340" r="5" fill="#3a5a7a" stroke="rgba(42,140,255,0.4)" stroke-width="1.5"/>
    <circle cx="140" cy="240" r="5" fill="#3a5a7a" stroke="rgba(42,140,255,0.4)" stroke-width="1.5"/>

    <!-- Arcs limite ±16.5° (indicatifs) -->
    <path d="M 218 108 A 34 34 0 0 1 262 108"
          fill="none" stroke="rgba(240,78,104,0.25)" stroke-width="1.5" stroke-dasharray="3,3"/>
    <path d="M 372 218 A 34 34 0 0 1 372 262"
          fill="none" stroke="rgba(240,78,104,0.25)" stroke-width="1.5" stroke-dasharray="3,3"/>
    <path d="M 262 372 A 34 34 0 0 1 218 372"
          fill="none" stroke="rgba(240,78,104,0.25)" stroke-width="1.5" stroke-dasharray="3,3"/>
    <path d="M 108 262 A 34 34 0 0 1 108 218"
          fill="none" stroke="rgba(240,78,104,0.25)" stroke-width="1.5" stroke-dasharray="3,3"/>

  </svg>

  <!-- Contrôles de test -->
  <div class="controls">
    <div class="ctrl-item">
      <div class="ctrl-label" style="color:#7b5af5">
        <span>G1 Sup</span>
        <span id="lblSup">0.0°</span>
      </div>
      <input type="range" id="slSup" min="-16.5" max="16.5" step="0.1" value="0"/>
    </div>
    <div class="ctrl-item">
      <div class="ctrl-label" style="color:#2a8cff">
        <span>G2 Tri</span>
        <span id="lblTri">0.0°</span>
      </div>
      <input type="range" id="slTri" min="-16.5" max="16.5" step="0.1" value="0"/>
    </div>
    <div class="ctrl-item">
      <div class="ctrl-label" style="color:#18d97a">
        <span>G3 Inf</span>
        <span id="lblInf">0.0°</span>
      </div>
      <input type="range" id="slInf" min="-16.5" max="16.5" step="0.1" value="0"/>
    </div>
    <div class="ctrl-item">
      <div class="ctrl-label" style="color:#f5a623">
        <span>G4 Bab</span>
        <span id="lblBab">0.0°</span>
      </div>
      <input type="range" id="slBab" min="-16.5" max="16.5" step="0.1" value="0"/>
    </div>
  </div>
</div>

<script>
// Echelle : 16.5° = 22px de rotation visuelle sur la pale
const SCALE = 1.33; // degrés → degrés SVG rotation

function setPale(id, valId, lblId, angleDeg, pivotX, pivotY) {
  const el  = document.getElementById(id);
  const val = document.getElementById(valId);
  const lbl = document.getElementById(lblId);
  if (!el) return;

  const rot = angleDeg * SCALE;
  el.setAttribute("transform", `rotate(${rot}, ${pivotX}, ${pivotY})`);

  const color = Math.abs(angleDeg) >= 16.5 ? "#f04e68"
              : Math.abs(angleDeg) >= 13.2 ? "#f5a623" : null;

  if (val) {
    val.textContent = angleDeg.toFixed(1) + "°";
    if (color) val.setAttribute("fill", color);
  }
  if (lbl) {
    lbl.textContent = angleDeg.toFixed(1) + "°";
    if (color) lbl.style.color = color;
    else lbl.style.color = "";
  }
}

document.getElementById("slSup").addEventListener("input", function() {
  setPale("govSup","valSup","lblSup", +this.value, 240, 140);
});
document.getElementById("slTri").addEventListener("input", function() {
  setPale("govTri","valTri","lblTri", +this.value, 340, 240);
});
document.getElementById("slInf").addEventListener("input", function() {
  setPale("govInf","valInf","lblInf", +this.value, 240, 340);
});
document.getElementById("slBab").addEventListener("input", function() {
  setPale("govBab","valBab","lblBab", +this.value, 140, 240);
});

// Fonction publique pour mise à jour depuis IHM
window.updateGouverneSchema = function(sup, tri, inf, bab) {
  document.getElementById("slSup").value = sup;
  document.getElementById("slTri").value = tri;
  document.getElementById("slInf").value = inf;
  document.getElementById("slBab").value = bab;
  setPale("govSup","valSup","lblSup", sup, 240, 140);
  setPale("govTri","valTri","lblTri", tri, 340, 240);
  setPale("govInf","valInf","lblInf", inf, 240, 340);
  setPale("govBab","valBab","lblBab", bab, 140, 240);
};
</script>

</body>
</html>
